---
import Base from '../layouts/Base.astro';
---

<Base>
  <main class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
      Spark <span class="text-sparkle">Commit</span>
    </h1>
    <p class="mt-6 text-lg text-ink-900 dark:text-ink-50">
      AI-powered git commit messages in VS Code — powered by your own Claude CLI.
    </p>
  </main>
</Base>
